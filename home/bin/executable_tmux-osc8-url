#!/usr/bin/env bash
# OSC 8-aware tmux URL picker.
#
# tmux-fzf-url's xre pipeline runs --strip-ansi before pattern matching, which
# also strips OSC 8 hyperlink escapes — taking the URL inside them with it. This
# wrapper captures the pane with escapes intact and runs a plain-text URL regex
# on the raw bytes. The URL inside an OSC 8 sequence is ASCII text sandwiched
# between escape markers, so a single regex pass catches both plain URLs and
# hyperlink URLs without needing to parse the escape sequences.
set -euo pipefail

content=$(tmux capture-pane -p -e -J)

urls=$(printf '%s\n' "$content" \
    | grep -oE '(https?|ftp|file)://[-A-Za-z0-9+&@#/%?=~_|!:,.;]*[-A-Za-z0-9+&@#/%=~_|]' \
    | awk '!seen[$0]++')

if [ -z "$urls" ]; then
    tmux display 'tmux-osc8-url: no URLs found'
    exit 0
fi

chosen=$(printf '%s\n' "$urls" | fzf-tmux -w 100% -h 50% --no-preview --exit-0)
[ -n "$chosen" ] && "$HOME/bin/open-url" "$chosen"
