#!/usr/bin/env bash
# Open a URL on the local machine.
# On macOS: uses `open` directly.
# On remote/Linux: sends OSC 1337 SetUserVar to WezTerm, which triggers the
# user-var-changed handler to run `open` on the local Mac.
url="$1"
if hash open &>/dev/null; then
    nohup open "$url" &>/dev/null
else
    encoded=$(printf '%s' "$url" | base64 | tr -d '\n')
    if [ -n "$TMUX" ]; then
        printf '\033Ptmux;\033\033]1337;SetUserVar=openurl=%s\a\033\\' "$encoded" > /dev/tty
    else
        printf '\033]1337;SetUserVar=openurl=%s\a' "$encoded" > /dev/tty
    fi
fi
