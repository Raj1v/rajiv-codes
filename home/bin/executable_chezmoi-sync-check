#!/bin/zsh
# One-shot chezmoi sync checker
# Runs periodically via launchd, writes status to cache

# Set up PATH for launchd (minimal environment)
eval "$(/opt/homebrew/bin/brew shellenv 2>/dev/null || /home/linuxbrew/.linuxbrew/bin/brew shellenv 2>/dev/null)" 2>/dev/null

CACHE_DIR="$HOME/.cache/chezmoi-sync"
STATUS_FILE="$CACHE_DIR/status"

mkdir -p "$CACHE_DIR"

SOURCE_DIR=$(chezmoi source-path 2>/dev/null) || exit 1
cd "$SOURCE_DIR"

issues=()

if ! chezmoi verify &>/dev/null; then
    issues+=("files")
fi

git fetch --quiet origin 2>/dev/null || true

if [[ -n $(git status --porcelain) ]]; then
    issues+=("dirty")
fi

local_commits=$(git rev-list --count @{u}..HEAD 2>/dev/null || echo "0")
if [[ $local_commits -gt 0 ]]; then
    issues+=("unpushed")
fi

remote_commits=$(git rev-list --count HEAD..@{u} 2>/dev/null || echo "0")
if [[ $remote_commits -gt 0 ]]; then
    issues+=("behind")
fi

if [[ ${#issues[@]} -eq 0 ]]; then
    printf 'TIMESTAMP=%s\nSTATUS=ok\nDETAILS=\n' "$(date +%s)" > "$STATUS_FILE"
else
    printf 'TIMESTAMP=%s\nSTATUS=drift\nDETAILS=%s\n' "$(date +%s)" "$(IFS=,; echo "${issues[*]}")" > "$STATUS_FILE"
fi
