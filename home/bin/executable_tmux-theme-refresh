#!/usr/bin/env bash
# Refresh tmux theme from the live terminal background.
# Run inside a tmux PTY (display-popup -E), NOT run-shell.
# Logs every step to /tmp/theme-refresh.log for debugging.

LOG=/tmp/theme-refresh.log
exec 9>>"$LOG"
echo "=== $(date) pid=$$ tty=$(tty 2>&1) ===" >&9

# Don't use `set -e` — we want to see *where* failures happen.
set -u

if ! exec 3<>/dev/tty 2>>"$LOG"; then
    echo "FAIL: cannot open /dev/tty" >&9
    tmux display-message "theme-refresh: /dev/tty unavailable (see $LOG)"
    exit 1
fi

old=$(stty -g <&3 2>>"$LOG")
echo "stty saved: ${old:0:60}..." >&9
trap 'stty "$old" <&3 2>>"$LOG"' EXIT

stty raw -echo min 0 time 10 <&3 2>>"$LOG"

# OSC 11 wrapped in tmux DCS passthrough.
printf '\ePtmux;\e\e]11;?\a\e\\' >&3
echo "OSC 11 sent" >&9

reply=$(dd bs=128 count=1 <&3 2>/dev/null || true)
echo "reply (${#reply} bytes):" >&9
printf '%s' "$reply" | od -c >&9 2>&1

stty "$old" <&3 2>>"$LOG"
trap - EXIT

rgb=$(printf '%s' "$reply" | LC_ALL=C grep -oE 'rgb:[0-9a-fA-F]{2,4}/[0-9a-fA-F]{2,4}/[0-9a-fA-F]{2,4}' | head -1 || true)
echo "parsed rgb: '$rgb'" >&9

if [ -z "$rgb" ]; then
    tmux display-message "theme-refresh: no OSC 11 reply — see $LOG"
    exit 1
fi

IFS=/ read -r r g b <<<"${rgb#rgb:}"
r=$((16#${r:0:2})); g=$((16#${g:0:2})); b=$((16#${b:0:2}))
luma=$(( (299*r + 587*g + 114*b) / 1000 ))
echo "r=$r g=$g b=$b luma=$luma" >&9

if [ "$luma" -lt 128 ]; then
    theme=dark; colorfgbg="15;0"; expected_flavor=mocha
else
    theme=light; colorfgbg="0;15"; expected_flavor=latte
fi

current_flavor=$(tmux show -gv @catppuccin_flavor 2>/dev/null || true)
echo "current='$current_flavor' expected='$expected_flavor'" >&9

if [ "$current_flavor" = "$expected_flavor" ]; then
    echo "no-op: theme already $theme" >&9
    exit 0
fi

tmux setenv -g LC_THEME "$theme"
tmux setenv -g COLORFGBG "$colorfgbg"
tmux source-file ~/.tmux.conf
tmux display-message "theme: $theme (bg $(printf '%02x%02x%02x' $r $g $b), luma $luma)"
echo "applied: $theme" >&9
