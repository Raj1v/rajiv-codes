# Dotfiles sync check on startup

export PATH="/opt/homebrew/opt/openssh/bin:$PATH"

# Tmux session picker on shell start (skip in IDE terminals)
if [[ -z "$TMUX" && $- == *i* && "$TERM_PROGRAM" != "vscode" && -z "$CURSOR_AGENT" ]]; then
  # Read dotfiles sync status from daemon cache (instant, no network calls)
  if [[ -f "$HOME/.cache/chezmoi-sync/status" ]]; then
    source "$HOME/.cache/chezmoi-sync/status"
    if [[ "$STATUS" = "drift" ]]; then
      echo "⚠ Dotfiles out of sync: $DETAILS"
      echo "  Run 'chezmoi-sync' to resolve"
      echo ""
    fi
    unset TIMESTAMP STATUS DETAILS
  fi

  session=$(sesh list | fzf --prompt="⚡ ")
  [[ -n "$session" ]] && exec sesh connect "$session"
fi

