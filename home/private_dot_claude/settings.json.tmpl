{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt|elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "workmux set-window-status waiting"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "workmux set-window-status working"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "workmux set-window-status done"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "workmux set-window-status working"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node \"{{ .chezmoi.homeDir }}/.claude/hooks/statusline.js\""
  },
  "enabledPlugins": {
    "recall@recall-marketplace": true
  },
  "effortLevel": "high",
  "voiceEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "mcpServers": {
    "tmux": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "tmux-mcp", "--shell-type=zsh"],
      "env": {}
    },
    "metabase": {
      "command": "npx",
      "args": ["-y", "@cognitionai/metabase-mcp-server", "--all"],
      "env": {
        "METABASE_URL": "https://metabase.studyflash.ch/",
        "METABASE_API_KEY": "{{ env "METABASE_API_KEY" }}"
      }
    },
    "automation": {
      "type": "http",
      "url": "https://automation.studyflash.ch/mcp-server/http"
    }
  }
}
